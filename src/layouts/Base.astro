---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
}
const {
  title = 'h11t labs',
  description = 'h11t labs is where I host and show my personal projects — mostly Python: scrapers, search, and background tooling.',
  type = 'website',
} = Astro.props;

const fullTitle = title === 'h11t labs' ? title : `${title} — h11t labs`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- set saved language + theme before paint (no flash); URLs stay the same -->
    <script is:inline>
      try {
        var l = localStorage.getItem('lang');
        if (l === 'nl' || l === 'en') document.documentElement.lang = l;
        var t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="color-scheme" content="light dark" />

    <meta property="og:site_name" content="h11t labs" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;1,8..60,400&family=JetBrains+Mono:wght@400;500;700&family=Poppins:ital,wght@0,700;1,800&display=swap"
    />
    <link rel="alternate" type="application/rss+xml" title="h11t labs" href="/rss.xml" />
    <link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <div class="layout">
      <Sidebar />
      <main id="main" class="main">
        <slot />
      </main>
    </div>

    <style>
      .layout {
        display: grid;
        grid-template-columns: var(--sidebar-w) minmax(0, 1fr);
        align-items: start;
      }
      .main {
        padding: clamp(2.5rem, 6vw, 4.5rem) var(--gutter) 5rem;
        max-width: calc(var(--content-w) + var(--gutter) * 2);
        /* center the content column within the space beside the sidebar,
           while keeping the text itself left-aligned */
        margin-inline: auto;
        width: 100%;
      }
      @media (max-width: 820px) {
        .layout { grid-template-columns: 1fr; }
        .main { max-width: 100%; }
      }
    </style>

    <script is:inline>
      window.setLang = function (l) {
        if (l !== 'en' && l !== 'nl') return;
        document.documentElement.lang = l;
        try { localStorage.setItem('lang', l); } catch (e) {}
        document.querySelectorAll('[data-lang-btn]').forEach(function (b) {
          b.setAttribute('aria-pressed', String(b.getAttribute('data-lang-btn') === l));
        });
      };

      function themeMode() {
        try { return localStorage.getItem('theme') || 'auto'; } catch (e) { return 'auto'; }
      }
      function reflectTheme(m) {
        document.querySelectorAll('[data-theme-opt]').forEach(function (b) {
          b.setAttribute('aria-pressed', String(b.getAttribute('data-theme-opt') === m));
        });
      }
      window.setTheme = function (m) {
        if (m !== 'auto' && m !== 'light' && m !== 'dark') return;
        if (m === 'auto') document.documentElement.removeAttribute('data-theme');
        else document.documentElement.setAttribute('data-theme', m);
        try { localStorage.setItem('theme', m); } catch (e) {}
        reflectTheme(m);
      };

      // reflect the active language + theme on the selectors on load
      document.addEventListener('DOMContentLoaded', function () {
        var l = document.documentElement.lang === 'nl' ? 'nl' : 'en';
        document.querySelectorAll('[data-lang-btn]').forEach(function (b) {
          b.setAttribute('aria-pressed', String(b.getAttribute('data-lang-btn') === l));
        });
        reflectTheme(themeMode());
      });
    </script>
  </body>
</html>
