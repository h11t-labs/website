---
import Logo from './Logo.astro';
import T from './T.astro';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');

const nav = [
  { n: '00', href: '/', en: 'home', nl: 'home' },
  { n: '01', href: '/work', en: 'projects', nl: 'projecten' },
  { n: '02', href: '/writing', en: 'writing', nl: 'artikelen' },
  { n: '03', href: '/about', en: 'about', nl: 'over' },
];
// note: /system (the styleguide) is intentionally not in the nav — it's a
// personal reference, dev-only, and excluded from the production build.
---

<aside class="sidebar">
  <div class="sidebar__top">
    <a href="/" class="brand"><Logo fluid /></a>
  </div>

  <nav class="nav" aria-label="Primary">
    {nav.map((item) => (
      <a
        href={item.href}
        class:list={['nav__row', { 'is-active': isActive(item.href) }]}
        aria-current={isActive(item.href) ? 'page' : undefined}
      >
        <span class="nav__n">{item.n}</span>
        <span class="nav__label"><T en={item.en} nl={item.nl} /></span>
      </a>
    ))}
  </nav>

  <div class="sidebar__foot">
    <div class="foot__controls">
      <div class="langsel" role="group" aria-label="Language">
        <button type="button" class="langsel__btn" data-lang-btn="en" onclick="setLang('en')">EN</button>
        <span class="langsel__sep">/</span>
        <button type="button" class="langsel__btn" data-lang-btn="nl" onclick="setLang('nl')">NL</button>
      </div>

      <div class="themesel" role="group" aria-label="Theme">
        <button type="button" class="themesel__btn" data-theme-opt="auto" onclick="setTheme('auto')">auto</button>
        <span class="langsel__sep">/</span>
        <button type="button" class="themesel__btn" data-theme-opt="light" onclick="setTheme('light')">light</button>
        <span class="langsel__sep">/</span>
        <button type="button" class="themesel__btn" data-theme-opt="dark" onclick="setTheme('dark')">dark</button>
      </div>
    </div>
    <p class="foot__links">
      <a href="https://github.com/h11t-labs" target="_blank" rel="noopener">github</a>
      <a href="mailto:hi@h11t-labs.nl">mail</a>
      <a href="/llms.txt">llms</a>
    </p>
  </div>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
    padding: 2.4rem 2rem;
    min-height: 100dvh;
    border-right: 1px solid var(--border);
    position: sticky;
    top: 0;
  }
  /* the wordmark scales with the sidebar column, leaving a right margin */
  .brand { display: block; container-type: inline-size; --logo-size: 20cqi; }
  .brand:hover { text-decoration: none; }

  .nav { display: flex; flex-direction: column; border-top: 1px solid var(--border); }
  .nav__row {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }
  .nav__row:hover { text-decoration: none; }
  .nav__n {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--index);
    min-width: 1.4rem;
  }
  .nav__label {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--muted);
    transition: color .15s ease;
  }
  .nav__row:hover .nav__label { color: var(--text); }
  .nav__row.is-active .nav__n,
  .nav__row.is-active .nav__label { color: var(--amber); }

  .sidebar__foot { margin-top: auto; display: flex; flex-direction: column; gap: 1.1rem; }
  .foot__controls { display: flex; flex-direction: column; gap: 0.8rem; }

  .langsel { display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.8rem; }
  .langsel__btn {
    appearance: none;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    font: inherit;
    color: var(--index);
    transition: color .12s ease;
  }
  .langsel__btn:hover { color: var(--muted); }
  .langsel__btn[aria-pressed='true'] { color: var(--amber); }
  .langsel__sep { color: var(--index); }

  .themesel { display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.8rem; }
  .themesel__btn {
    appearance: none;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    font: inherit;
    color: var(--index);
    transition: color .12s ease;
  }
  .themesel__btn:hover { color: var(--muted); }
  .themesel__btn[aria-pressed='true'] { color: var(--amber); }

  .foot__links { display: flex; gap: 1.1rem; margin: 0; font-family: var(--font-mono); font-size: 0.75rem; }
  .foot__links a { color: var(--muted); }
  .foot__links a:hover { color: var(--amber); text-decoration: none; }

  /* On narrow screens the sidebar becomes a top bar */
  @media (max-width: 820px) {
    .sidebar {
      min-height: auto;
      position: static;
      border-right: 0;
      border-bottom: 1px solid var(--border);
      padding: 1.4rem var(--gutter);
      gap: 1.2rem;
    }
    /* on the mobile top-bar the brand is auto-width, so use a fixed logo size */
    .brand { display: inline-block; container-type: normal; --logo-size: 30px; }
    .nav { flex-direction: row; flex-wrap: wrap; gap: 0.1rem 1.4rem; border-top: 0; }
    .nav__row { border-bottom: 0; padding: 0.3rem 0; gap: 0.4rem; }
    .nav__n { display: none; }
    .foot__links { display: none; }
    .sidebar__foot { margin-top: 0; flex-direction: row; flex-wrap: wrap; align-items: center; justify-content: flex-start; gap: 0.7rem 1.6rem; }
    .foot__controls { flex-direction: row; gap: 1.6rem; }
  }
</style>
